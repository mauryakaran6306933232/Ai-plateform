{
  "name": "ai-platform",
  "version": "1.0.0",
  "private": true,
  "description": "FAANG-Level AI Platform — Multi-Agent + AI OS + Multimodal Analytics",
  "workspaces": [
    "apps/*",
    "shared/*"
  ],
  "scripts": {
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:backend": "cd apps/backend && python -m uvicorn app.main:app --reload --reload-dir app --port 8000",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "cd apps/frontend && npm run build",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "monitoring:up": "docker compose -f infra/docker/docker-compose.monitoring.yml up -d"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}