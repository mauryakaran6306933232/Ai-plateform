# ====================================
# APPLICATION
# ====================================
APP_NAME=AI-Platform
APP_ENV=production
APP_PORT=8000
FRONTEND_URL=https://your-frontend.vercel.app

# ====================================
# DATABASE (Set these in Render Dashboard)
# ====================================
# DATABASE_URL is auto-set by Render PostgreSQL
POSTGRES_HOST=<from-render-postgres>
POSTGRES_PORT=5432
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=<from-render-postgres>
POSTGRES_DB=aiplatform

# ====================================
# REDIS (Set these in Render Dashboard)
# ====================================
REDIS_HOST=<from-render-redis>
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================================
# CHROMADB (Using local PersistentClient on Render)
# ====================================
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=/app/chroma_data

# ====================================
# WORKSPACE
# ====================================
WORKSPACE_DIR=/app/workspace

# ====================================
# OLLAMA (Point to your Ollama server)
# ====================================
OLLAMA_BASE_URL=http://your-ollama-server:11434
OLLAMA_DEFAULT_MODEL=llama3

# ====================================
# JWT AUTH
# ====================================
JWT_SECRET=<generate-a-random-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ====================================
# GITHUB INTEGRATION
# ====================================
GITHUB_TOKEN=

# ====================================
# PYTHON
# ====================================
PYTHONUNBUFFERED=1